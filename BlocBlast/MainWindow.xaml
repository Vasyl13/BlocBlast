<Window x:Class="BlockBlast.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Block Blast"
        Height="920"
        Width="620"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="#1565D8">

    <Grid>

        <!-- MENU -->

        <Grid x:Name="MenuPanel">

            <Grid.Background>
                <LinearGradientBrush StartPoint="0,0"
                                     EndPoint="0,1">
                    <GradientStop Color="#0D47C9"
                                  Offset="0"/>
                    <GradientStop Color="#1565D8"
                                  Offset="1"/>
                </LinearGradientBrush>
            </Grid.Background>

            <StackPanel VerticalAlignment="Center"
                        HorizontalAlignment="Center">

                <TextBlock Text="BLOCK BLAST"
                           Foreground="White"
                           FontSize="42"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,40"/>

                <Button x:Name="PlayButton"
                        Width="300"
                        Height="90"
                        Click="PlayButton_Click"
                        Content="Classic"
                        FontSize="34"
                        FontWeight="Bold"
                        Foreground="White"
                        Cursor="Hand"
                        BorderThickness="0">

                    <Button.Background>
                        <LinearGradientBrush StartPoint="0,0"
                                             EndPoint="0,1">
                            <GradientStop Color="#22F04B"
                                          Offset="0"/>

                            <GradientStop Color="#17B836"
                                          Offset="1"/>
                        </LinearGradientBrush>
                    </Button.Background>

                </Button>

            </StackPanel>

        </Grid>

        <!-- GAME -->

        <Grid x:Name="GamePanel"
              Visibility="Collapsed">

            <Grid.RowDefinitions>
                <RowDefinition Height="100"/>
                <RowDefinition Height="540"/>
                <RowDefinition Height="220"/>
            </Grid.RowDefinitions>

            <!-- TOP PANEL -->

            <Grid Margin="20,15,20,0">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="140"/>
                </Grid.ColumnDefinitions>

                <!-- BACK BUTTON -->

                <Button x:Name="MenuButton"
                        Grid.Column="0"
                        Width="70"
                        Height="50"
                        Click="MenuButton_Click"
                        Content="←"
                        FontSize="26"
                        FontWeight="Bold"
                        Background="#2A2A40"
                        Foreground="White"
                        BorderThickness="0"/>

                <!-- SCORE -->

                <StackPanel Grid.Column="1"
                            HorizontalAlignment="Center">

                    <TextBlock Text="SCORE"
                               Foreground="White"
                               FontSize="20"
                               HorizontalAlignment="Center"/>

                    <TextBlock x:Name="ScoreText"
                               Text="0"
                               FontSize="44"
                               FontWeight="Bold"
                               Foreground="Gold"
                               HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- BEST -->

                <StackPanel Grid.Column="2"
                            HorizontalAlignment="Center">

                    <TextBlock Text="BEST"
                               Foreground="White"
                               FontSize="20"
                               HorizontalAlignment="Center"/>

                    <TextBlock x:Name="BestText"
                               Text="0"
                               FontSize="44"
                               FontWeight="Bold"
                               Foreground="Lime"
                               HorizontalAlignment="Center"/>
                </StackPanel>

            </Grid>

            <!-- BOARD -->

            <Grid Grid.Row="1"
                  HorizontalAlignment="Center"
                  VerticalAlignment="Center">

                <Border Width="520"
                        Height="520"
                        CornerRadius="25"
                        Background="#1C2342"/>

                <UniformGrid x:Name="BoardGrid"
                             Width="500"
                             Height="500"
                             Rows="8"
                             Columns="8"/>

                <!-- PREVIEW -->

                <Canvas x:Name="PreviewCanvas"
                        Width="500"
                        Height="500"
                        IsHitTestVisible="False"/>

            </Grid>

            <!-- SHAPES -->

            <Grid Grid.Row="2"
                  Margin="0,20,0,0">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>

                <Canvas x:Name="ShapeCanvas1"
                        Grid.Column="0"
                        Width="180"
                        Height="160"
                        Background="Transparent"/>

                <Canvas x:Name="ShapeCanvas2"
                        Grid.Column="1"
                        Width="180"
                        Height="160"
                        Background="Transparent"/>

                <Canvas x:Name="ShapeCanvas3"
                        Grid.Column="2"
                        Width="180"
                        Height="160"
                        Background="Transparent"/>

            </Grid>

        </Grid>

    </Grid>

</Window>